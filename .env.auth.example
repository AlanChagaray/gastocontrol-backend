# Variables de Entorno - Sistema de Autenticación

# Estas son las variables necesarias que debes agregar a tu archivo .env

# ======================
# Google OAuth
# ======================
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_REDIRECT_URI=${APP_URL}/api/auth/google/callback

# ======================
# Configuración de Email
# ======================
# Para desarrollo puedes usar Mailtrap: https://mailtrap.io/
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=tu_username_mailtrap
MAIL_PASSWORD=tu_password_mailtrap
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@gastocontrol.com
MAIL_FROM_NAME="${APP_NAME}"

# Para producción con Gmail:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu_email@gmail.com
# MAIL_PASSWORD=tu_app_password
# MAIL_ENCRYPTION=tls

# ======================
# Database PostgreSQL
# ======================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gastocontrol
DB_USERNAME=postgres
DB_PASSWORD=tu_password

# ======================
# Frontend URL
# ======================
# URL de tu aplicación frontend (para redireccionamientos después de verificar email, etc)
FRONTEND_URL=http://localhost:3000

# ======================
# Sanctum
# ======================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000
SESSION_DRIVER=cookie
SESSION_DOMAIN=localhost
